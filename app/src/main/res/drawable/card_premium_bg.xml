<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Shape -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>

    <!-- Subtle Texture / Gradient (Brushed Metal feel) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="45"
                android:centerX="50%"
                android:centerY="50%"
                android:startColor="#0DFFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#05FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
