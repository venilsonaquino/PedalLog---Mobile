<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ══ Full-screen map background ══════════════════════════════════════ -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark" />

    <!-- ══ Loading indicator — shown while DB data is being processed ═══════ -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="160dp"
        app:indicatorColor="@color/primary"
        app:trackColor="#1AFFFFFF"
        app:indicatorSize="48dp"
        app:trackThickness="4dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- ══ Top bar overlay (gradient fade top→transparent) ════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/top_bar_gradient"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/card_bg"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Dom, 26 abr · 12:47"
                android:textColor="@color/on_background"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvDetailUuid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalhe da Sessão"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══ Persistent Bottom Sheet ═════════════════════════════════════════
         peekHeight = handle (28dp) + summary strip (~60dp) ≈ 88dp
         isFitToContents=false enables 3 states: collapsed / half / expanded
    ════════════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheetContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="92dp"
        app:behavior_hideable="false"
        app:behavior_skipCollapsed="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ── Drag handle ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="#40ffffff" />
            </LinearLayout>

            <!-- ══ Unified Metrics Grid (Peek + Expanded) ══════════════ -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:columnCount="2"
                android:useDefaultMargins="false"
                android:clipToPadding="false"
                android:clipChildren="false">

                <!-- 1. Distância (Primary Highlight) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_metric_primary"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginBottom="4dp"
                            android:src="@drawable/ic_pin"
                            app:tint="#2ECC71" />

                        <TextView
                            android:id="@+id/tvMetricDistanceValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            tools:text="1.19"
                            android:textColor="#2ECC71"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false" />

                        <TextView
                            android:id="@+id/tvMetricDistanceUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="2dp"
                            android:text="km"
                            android:textColor="#2ECC71"
                            android:alpha="0.5"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="24dp"
                        android:text="Distância"
                        android:textColor="#9AA0A6"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 2. Duração -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_metric_secondary"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#9AA0A6" />

                        <TextView
                            android:id="@+id/tvMetricDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            tools:text="00:16:33"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="24dp"
                        android:text="Duração"
                        android:textColor="#9AA0A6"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 3. Vel. Média -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_metric_secondary"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginBottom="3dp"
                            android:src="@drawable/ic_lightning"
                            app:tint="#9AA0A6" />

                        <TextView
                            android:id="@+id/tvMetricAvgSpeedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            tools:text="4.7"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="2dp"
                            android:text="km/h"
                            android:textColor="#9AA0A6"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="24dp"
                        android:text="Vel. Média"
                        android:textColor="#9AA0A6"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 4. Vel. Máx. -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_metric_secondary"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginBottom="3dp"
                            android:src="@drawable/ic_chart"
                            app:tint="#9AA0A6" />

                        <TextView
                            android:id="@+id/tvMetricMaxSpeedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            tools:text="6.4"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="2dp"
                            android:text="km/h"
                            android:textColor="#9AA0A6"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="24dp"
                        android:text="Vel. Máx."
                        android:textColor="#9AA0A6"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 5. Pontos GPS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_metric_secondary"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_target"
                            app:tint="#9AA0A6" />

                        <TextView
                            android:id="@+id/tvMetricPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            tools:text="1245"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="24dp"
                        android:text="Pontos GPS"
                        android:textColor="#9AA0A6"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 6. Protocolo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_metric_secondary"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chip"
                            app:tint="#9AA0A6" />

                        <TextView
                            android:id="@+id/tvMetricProtocol"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="GZIP+CSV"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="24dp"
                        android:text="Protocolo"
                        android:textColor="#9AA0A6"
                        android:textSize="11sp" />
                </LinearLayout>

            </GridLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/surface_container"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VELOCIDADE AO LONGO DO TEMPO"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/speedChart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Technical UUID ─────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvTechnicalUuid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center"
                android:textColor="#26FFFFFF"
                android:textSize="9sp"
                android:fontFamily="monospace"
                tools:text="UUID · mock-modjj0h3-ra1qco3" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
